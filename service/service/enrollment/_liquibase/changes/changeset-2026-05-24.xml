<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1" author="mohamed.ehab">
        <createTable tableName="oa_enrollment_type">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(250)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_by_id" type="int"/>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="mohamed.ehab">
        <createTable tableName="oa_enrollment">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trainee_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="course_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="trainer_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="enrollment_type_id" type="int"/>
            <column name="start_date" type="date"/>
            <column name="end_date" type="date"/>
            <column name="enrollment_status" type="int"/>
            <column name="payment_status" type="int"/>
            <column name="subscription_value" type="Integer"/>
            <column name="discount_amount" type="integer" defaultValueNumeric="0"/>
            <column name="discount_percentage" type="decimal(5,2)" defaultValueNumeric="0.00"/>
            <column name="final_subscription_value" type="Integer"/>
            <column name="remained_subscription_value" type="Integer"/>
            <column name="note" type="text"/>
            <column name="is_active" type="boolean" defaultValueBoolean="true"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_on" type="timestamp"/>
            <column name="created_by_id" type="int"/>
            <column name="last_modified_by_id" type="int"/>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <addUniqueConstraint
                constraintName="uq_trainee_course"
                tableName="oa_enrollment"
                columnNames="trainee_id,course_id,enrollment_type_id,start_date"/>

        <addForeignKeyConstraint
                constraintName="fk_enrollment_type"
                baseTableName="oa_enrollment"
                baseColumnNames="enrollment_type_id"
                referencedTableName="oa_enrollment_type"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_enrollment_trainee"
                baseTableName="oa_enrollment"
                baseColumnNames="trainee_id"
                referencedTableName="oa_trainee"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_enrollment_course"
                baseTableName="oa_enrollment"
                baseColumnNames="course_id"
                referencedTableName="oa_course"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_enrollment_trainer"
                baseTableName="oa_enrollment"
                baseColumnNames="trainer_id"
                referencedTableName="oa_employee"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_enrollment_created_by"
                baseTableName="oa_enrollment"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_enrollment_modified_by"
                baseTableName="oa_enrollment"
                baseColumnNames="last_modified_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

    </changeSet>

</databaseChangeLog>