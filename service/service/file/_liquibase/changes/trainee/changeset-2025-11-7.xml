<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">


    <changeSet id="1" author="mohamed.ehab">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*)
                FROM sc_domain
                WHERE id = 5002;
            </sqlCheck>
        </preConditions>
        <insert tableName="sc_domain">
            <column name="id" valueComputed="5002"/>
            <column name="title_en" value="Trainee"/>
            <column name="title_ar" value="Trainee"/>
        </insert>
    </changeSet>

    <changeSet id="2" author="mohamed.ehab">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*)
                FROM sc_domain
                WHERE id = 5003;
            </sqlCheck>
        </preConditions>
        <insert tableName="sc_domain">
            <column name="id" valueComputed="5003"/>
            <column name="title_en" value="Trainee Certificate"/>
            <column name="title_ar" value="شهادات المتدربين"/>
        </insert>
    </changeSet>

    <changeSet id="3" author="alaa.esam">
        <insert tableName="fl_domain_config">
            <column name="domain_id" valueComputed="5002"/>
            <column name="base_folder" value="/trainee"/>
            <column name="label" value="trainee"/>
            <column name="max_size" value="10485760"/>
            <column name="allowed_extensions" value="jpg,png"/>
            <column name="last_modified_on" valueComputed="NULL"/>
            <column name="last_modified_by_id" valueComputed="NULL"/>
        </insert>
    </changeSet>

    <changeSet id="4" author="alaa.esam">
        <insert tableName="fl_domain_config">
            <column name="domain_id" valueComputed="5003"/>
            <column name="base_folder" value="/trainee_certificate"/>
            <column name="label" value="trainee_certificate"/>
            <column name="max_size" value="10485760"/>
            <column name="allowed_extensions" value="jpg,png"/>
            <column name="last_modified_on" valueComputed="NULL"/>
            <column name="last_modified_by_id" valueComputed="NULL"/>
        </insert>
    </changeSet>

</databaseChangeLog>
