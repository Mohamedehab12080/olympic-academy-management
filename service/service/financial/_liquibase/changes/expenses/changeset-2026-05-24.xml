<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1" author="mohamed.ehab">
        <createTable tableName="oa_expense_type">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(250)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="is_active" type="boolean"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_expense_type_created_by"
                baseTableName="oa_expense_type"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="2" author="mohamed.ehab">
        <createTable tableName="oa_expense">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="expense_date" type="date"/>
            <column name="amount_expensed" type="Integer"/>
            <column name="payment_method_id" type="int"/>
            <column name="expense_type_id" type="int"/>
            <column name="images_urls" type="json"/>
            <column name="note" type="text"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on" type="timestamp"/>
            <column name="created_by_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by_id" type="int"/>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_expense_payment_method"
                baseTableName="oa_expense"
                baseColumnNames="payment_method_id"
                referencedTableName="oa_payment_method"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_expense_created_by"
                baseTableName="oa_expense"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_expense_modified_by"
                baseTableName="oa_expense"
                baseColumnNames="last_modified_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

    </changeSet>

</databaseChangeLog>