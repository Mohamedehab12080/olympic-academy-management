<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1" author="mohamed.ehab">
        <createTable tableName="oa_employee">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="full_name" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="national_id" type="char(14)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="birth_date" type="date"/>
            <column name="gender" type="int"/>
            <column name="salary" type="Integer"/>
            <column name="remained_salary" type="Integer"/>
            <column name="salary_type" type="int"/>
            <column name="employee_type" type="int"/>
            <column name="image_url" type="varchar(255)"/>
            <column name="hire_date" type="date"/>
            <column name="is_active" type="boolean" defaultValueBoolean="true"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_by_id" type="int"/>
            <column name="last_modified_by_id" type="int"/>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_employee_created_by"
                baseTableName="oa_employee"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_employee_modified_by"
                baseTableName="oa_employee"
                baseColumnNames="last_modified_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="2" author="mohamed.ehab">
        <createTable tableName="oa_employee_contact">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="employee_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="contact_type" type="int"/>
            <column name="contact_value" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_on" type="timestamp"/>
            <column name="created_by_id" type="int"/>
            <column name="last_modified_by_id" type="int"/>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_emp_contact_employee"
                baseTableName="oa_employee_contact"
                baseColumnNames="employee_id"
                referencedTableName="oa_employee"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                constraintName="fk_emp_contact_created_by"
                baseTableName="oa_employee_contact"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_emp_contact_modified_by"
                baseTableName="oa_employee_contact"
                baseColumnNames="last_modified_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>
    </changeSet>


    <changeSet id="3" author="mohamed.ehab">
        <createTable tableName="oa_employee_department">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="employee_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="department_id" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_employee_department_employee"
                baseTableName="oa_employee_department"
                baseColumnNames="employee_id"
                referencedTableName="oa_employee"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                constraintName="fk_employee_department_department"
                baseTableName="oa_employee_department"
                baseColumnNames="department_id"
                referencedTableName="oa_department"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>


</databaseChangeLog>