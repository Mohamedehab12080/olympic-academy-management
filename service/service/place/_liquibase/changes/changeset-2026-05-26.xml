<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1" author="mohamed.ehab">
        <createTable tableName="oa_place">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(250)">
                <constraints nullable="false"/>
            </column>
            <column name="rent_value" type="int"/>
            <column name="remained_value" type="int"/>
            <column name="address" type="varchar(250)"/>
            <column name="phone_number" type="varchar(30)"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on" type="timestamp"/>
            <column name="created_by_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by_id" type="int"/>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_place_created_by"
                baseTableName="oa_place"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_place_modified_by"
                baseTableName="oa_place"
                baseColumnNames="last_modified_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>