<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <!-- ================================================================ -->
    <!-- Performance Indexes for Olympic Academy DB                       -->
    <!-- Author: mohamed.ehab                                             -->
    <!-- Date: 2026-07-14                                                 -->
    <!-- Purpose: Add high-value indexes for query optimization           -->
    <!-- ================================================================ -->

    <!-- ================================================================ -->
    <!-- 1. OA_COURSE_SESSION Table - Primary Indexes                   -->
    <!-- ================================================================ -->

    <!-- ⭐⭐⭐⭐⭐ COMPOSITE INDEX: Scheduling conflict detection -->
    <changeSet id="1" author="mohamed.ehab">
        <comment>Add composite index for scheduling conflict detection (employee + day + time)</comment>
        <createIndex tableName="oa_course_session" indexName="idx_session_employee_day_time">
            <column name="employee_id"/>
            <column name="session_day"/>
            <column name="start_time"/>
            <column name="end_time"/>
        </createIndex>
    </changeSet>

    <!-- ⭐⭐⭐ INDEX: Active course sessions per course -->
    <changeSet id="2" author="mohamed.ehab">
        <comment>Add index for active course sessions per course</comment>
        <createIndex tableName="oa_course_session" indexName="idx_session_course_status">
            <column name="course_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <!-- Supporting indexes for course_session -->
    <changeSet id="3" author="mohamed.ehab">
        <comment>Add index on course_id for faster session lookups</comment>
        <createIndex tableName="oa_course_session" indexName="idx_course_session_course_id">
            <column name="course_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="4" author="mohamed.ehab">
        <comment>Add index on employee_id for trainer schedule lookups</comment>
        <createIndex tableName="oa_course_session" indexName="idx_course_session_employee_id">
            <column name="employee_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="5" author="mohamed.ehab">
        <comment>Add index on place_id for venue-based queries</comment>
        <createIndex tableName="oa_course_session" indexName="idx_course_session_place_id">
            <column name="place_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================ -->
    <!-- 2. OA_ENROLLMENT Table - Primary Indexes                       -->
    <!-- ================================================================ -->

    <!-- ⭐⭐⭐⭐⭐ INDEX: Trainee enrollments with status -->
    <changeSet id="6" author="mohamed.ehab">
        <comment>Add composite index for trainee enrollments with status</comment>
        <createIndex tableName="oa_enrollment" indexName="idx_enrollment_trainee_status">
            <column name="trainee_id"/>
            <column name="enrollment_status"/>
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <!-- ⭐⭐⭐⭐ INDEX: Course enrollments with date range -->
    <changeSet id="7" author="mohamed.ehab">
        <comment>Add composite index for course enrollments with date range</comment>
        <createIndex tableName="oa_enrollment" indexName="idx_enrollment_course_dates">
            <column name="course_id"/>
            <column name="start_date"/>
            <column name="end_date"/>
        </createIndex>
    </changeSet>

    <!-- Supporting indexes for enrollment -->
    <changeSet id="8" author="mohamed.ehab">
        <comment>Add index for payment status financial reporting</comment>
        <createIndex tableName="oa_enrollment" indexName="idx_enrollment_payment_status">
            <column name="payment_status"/>
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <changeSet id="9" author="mohamed.ehab">
        <comment>Add index for trainer workload management</comment>
        <createIndex tableName="oa_enrollment" indexName="idx_enrollment_trainer_active">
            <column name="trainer_id"/>
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <!-- Additional dashboard indexes for enrollment -->
    <changeSet id="10" author="mohamed.ehab">
        <comment>Add index for enrollment dashboard count queries</comment>
        <createIndex tableName="oa_enrollment" indexName="idx_enrollment_created_active">
            <column name="created_on"/>
            <column name="is_active"/>
            <column name="is_deleted"/>
        </createIndex>
    </changeSet>

    <changeSet id="11" author="mohamed.ehab">
        <comment>Add index for enrollment status dashboard queries</comment>
        <createIndex tableName="oa_enrollment" indexName="idx_enrollment_created_status">
            <column name="created_on"/>
            <column name="enrollment_status"/>
            <column name="is_deleted"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================ -->
    <!-- 3. OA_TRAINEE_ATTENDANCE Table - Primary Indexes              -->
