<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1" author="mohamed.ehab">
        <createTable tableName="oa_constant">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(255)" />
            <column name="value" type="varchar(255)" />
            <column name="position" type="varchar(255)"/>
            <column name="created_on" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_by_id" type="int"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_constant_created_by"
                baseTableName="oa_constant"
                baseColumnNames="created_by_id"
                referencedTableName="oa_user"
                referencedColumnNames="id"/>

    </changeSet>

    <changeSet id="2" author="mohamed.ehab">
        <addColumn tableName="oa_constant">
            <column name="location" type="varchar(255)" />
        </addColumn>
    </changeSet>

</databaseChangeLog>