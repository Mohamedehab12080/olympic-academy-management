{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "olympic-academy-working": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/olympic-academy-working",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              {
                "glob": "**/*",
                "input": "node_modules/material-icons/iconfont",
                "output": "/assets/material-icons"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@fontsource/cairo/files",
                "output": "/assets/fonts/cairo"
              },
              {
                "glob": "**/*",
                "input": "node_modules/jsbarcode/dist",
                "output": "/assets/js"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/material-icons/iconfont/material-icons.css",
              "node_modules/@fontsource/cairo/index.css",
              "src/styles.css"
            ],
            "scripts": [
              "node_modules/jsbarcode/dist/JsBarcode.all.min.js"
            ],
            "allowedCommonJsDependencies": ["jsbarcode"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "999mb",
                  "maximumError": "999mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "999mb",
                  "maximumError": "999mb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "olympic-academy-working:build:production"
            },
            "development": {
              "browserTarget": "olympic-academy-working:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "olympic-academy-working:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}