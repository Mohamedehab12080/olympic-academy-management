<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1" author="mohamed.ehab">
        <createTable tableName="ctr_counter">
            <column name="id" type="integer">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title_en" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="title_ar" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="length" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="is_reset_daily" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="counter_starting_value" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="mohamed.ehab">
        <createTable tableName="ctr_counter_attribute">
            <column name="id" type="integer" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="counter_id" type="integer">
                <constraints nullable="false" foreignKeyName="fk_ctr_counter_attr_counter"
                             referencedTableName="ctr_counter" referencedColumnNames="id"/>
            </column>
            <column name="attribute_key" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="is_optional" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

    </changeSet>

    <!-- Create ctr_instance table -->
    <changeSet id="3" author="mohamed.ehab">
        <createTable tableName="ctr_counter_instance">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="counter_id" type="integer">
                <constraints nullable="false" foreignKeyName="fk_ctr_instance_counter"
                             referencedTableName="ctr_counter" referencedColumnNames="id"/>
            </column>
            <column name="counter_last_value" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

    </changeSet>

    <changeSet id="4" author="mohamed.ehab">
        <createTable tableName="ctr_counter_instance_attribute">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="counter_instance_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ctr_counter_instance_attr_counter_instance"
                             referencedTableName="ctr_counter_instance" referencedColumnNames="id"/>
            </column>
            <column name="attribute_key" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_value" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

<!--                <createIndex tableName="ctr_counter_instance_attribute" indexName="idx_ctr_counter_instance_attr_counter_instance">-->
<!--                    <column name="counter_instance_id"/>-->
<!--                </createIndex>-->

<!--                <createIndex tableName="ctr_counter_instance_attribute" indexName="idx_ctr_counter_instance_attr_key_value">-->
<!--                    <column name="attribute_key"/>-->
<!--                    <column name="attribute_value"/>-->
<!--                </createIndex>-->
    </changeSet>

</databaseChangeLog>